# ─── Daml JSON Ledger API ──────────────────────────────────────────────────
# URL of the JSON API server started by `daml start`
LEDGER_JSON_API_URL=http://localhost:7575

# ─── Party identifiers ─────────────────────────────────────────────────────
# Canton party IDs are long strings: DisplayName::hex-hash
# How to get them after running `daml start`:
#   curl http://localhost:7575/v1/parties \
#     -H "Authorization: Bearer YOUR_ADMIN_TOKEN"
#
# Or read them from the `daml start` console output — they're printed when
# Setup.daml runs.
ALICE_PARTY=Alice::1220...
BOB_PARTY=Bob::1220...
OPERATOR_PARTY=Operator::1220...

# ─── JWT tokens (one per party) ────────────────────────────────────────────
# Generate tokens with the Daml CLI:
#   daml ledger token --host localhost --port 6865 "Alice::1220..."
#
# Then run the demos with:
#   pnpm demo:swap
#   pnpm demo:batch
#
# For the sandbox in dev mode (--allow-insecure-tokens), any well-formed JWT
# with the correct actAs claim is accepted.
ALICE_TOKEN=eyJ...
BOB_TOKEN=eyJ...
OPERATOR_TOKEN=eyJ...
